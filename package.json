{
  "name": "@kongyo2/deepwiki-ask",
  "version": "0.1.3",
  "description": "DeepWiki MCP ask_question ツールのラッパー MCPサーバー",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deepwiki-ask": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "oxlint --silent",
    "lint:strict": "oxlint --deny-warnings",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm run build",
    "inspector:list": "npx @modelcontextprotocol/inspector --cli node dist/index.js --method tools/list",
    "inspector:call": "npx @modelcontextprotocol/inspector --cli node dist/index.js --method tools/call --tool-name ask_question"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "deepwiki",
    "ai",
    "github",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kongyo2/deepwiki-ask"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "neverthrow": "^8.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "oxlint": "^0.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
